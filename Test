-- Orion UI 로드
local OrionLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/Qanuir/orion-ui/refs/heads/main/source.lua"))()

local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer
local missiles = {}
local targetList = {}

local bombExplode = ReplicatedStorage:WaitForChild("BombEvents"):WaitForChild("BombExplode")
local setOwnerRemote = ReplicatedStorage:WaitForChild("GrabEvents"):WaitForChild("SetNetworkOwner")

-- [ UI 설정 (Orion UI) ]
local Window = OrionLib:MakeWindow({
    Name = "🚀 다각도 포격 시스템",
    HidePremium = true,
    SaveConfig = false,
    ConfigFolder = "MissileSystem"
})

local MainTab = Window:MakeTab({
    Name = "제어판",
    Icon = "rbxassetid://4483345998",
    PremiumOnly = false
})

-- 타겟 선택 드롭다운 (Orion UI에서는 단일 선택만 지원)
-- 그래도 원본과 동일하게 유지하기 위해 드롭다운 사용
MainTab:AddSection({
    Name = "🎯 타겟 설정"
})

local targetDropdown = MainTab:AddDropdown({
    Name = "타겟 선택",
    Default = "",
    Options = {},
    Callback = function(Value)
        -- Orion UI 드롭다운은 단일 선택이므로, 선택된 값을 리스트에 넣음
        targetList = {Value}
    end
})

local function updateList()
    local names = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then
            table.insert(names, p.Name)
        end
    end
    targetDropdown:Refresh(names, true)
end

MainTab:AddButton({
    Name = "🔄 목록 새로고침",
    Callback = function()
        updateList()
        OrionLib:MakeNotification({
            Name = "새로고침 완료",
            Content = "플레이어 목록이 업데이트되었습니다",
            Image = "rbxassetid://4483345998",
            Time = 2
        })
    end
})

task.spawn(updateList)

-- [ 기능: 미사일 소환 (F) ]
function spawnMissile()
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not root or #missiles >= 20 then return end
    
    local spawnRemote = ReplicatedStorage:WaitForChild("MenuToys"):WaitForChild("SpawnToyRemoteFunction")
    local spawnCF = root.CFrame * CFrame.new(0, 30, 0)
    
    pcall(function() 
        spawnRemote:InvokeServer("BombMissile", spawnCF, Vector3.new(0, -1.86, 0)) 
    end)
    
    task.spawn(function()
        local folder = workspace:WaitForChild(player.Name .. "SpawnedInToys", 5)
        if folder then
            for i = 1, 10 do
                for _, m in pairs(folder:GetChildren()) do
                    if m.Name == "BombMissile" and not table.find(missiles, m) then
                        local hb = m:FindFirstChild("HitboxBodyTop")
                        if hb then
                            hb.CanCollide = false
                            hb.CanTouch = false
                            setOwnerRemote:FireServer(hb, hb.CFrame)
                            table.insert(missiles, m)
                            task.delay(0.3, function() if hb then hb.CanTouch = true end end)
                        end
                    end
                end
                task.wait(0.05)
            end
        end
    end)
end

-- [ 기능: 다각도 쇄도 및 Y-2 지점 강타 (G) ]
function fireAll()
    if #targetList == 0 or #missiles == 0 then return end

    local toFire = {unpack(missiles)}
    missiles = {} 

    for i, m in ipairs(toFire) do
        task.spawn(function()
            local hb = m:FindFirstChild("HitboxBodyTop")
            local targetName = targetList[((i-1) % #targetList) + 1]
            local targetPlayer = Players:FindFirstChild(targetName)
            
            if targetPlayer and targetPlayer.Character and hb then
                local tRoot = targetPlayer.Character:FindFirstChild("HumanoidRootPart")
                if tRoot then
                    hb.CanCollide = true
                    hb.CanTouch = true
                    
                    -- 1. 시작 지점 분산 (타겟 주변 하늘 사방으로 퍼뜨림)
                    local spreadAngle = math.rad(math.random(0, 360))
                    local spreadRadius = math.random(20, 40)
                    local startPos = tRoot.Position + Vector3.new(math.cos(spreadAngle) * spreadRadius, 50, math.sin(spreadAngle) * spreadRadius)
                    
                    hb.CFrame = CFrame.new(startPos, tRoot.Position)
                    task.wait(0.05) 

                    -- 2. 초고속 돌진 로직 (Y-2 지점으로 대각선 쇄도)
                    local startTime = tick()
                    while tick() - startTime < 0.3 and hb.Parent do
                        local currentTarget = tRoot.Position - Vector3.new(0, 2, 0)
                        local direction = (currentTarget - hb.Position).Unit
                        
                        hb.AssemblyLinearVelocity = direction * 700
                        hb.CFrame = CFrame.new(hb.Position, currentTarget)
                        
                        if (hb.Position - currentTarget).Magnitude < 4 then break end
                        task.wait()
                    end

                    -- 3. 충돌 및 폭발
                    if m.Parent then
                        local explosionArgs = {
                            {
                                Radius = 20,
                                TimeLength = 0.5,
                                Hitbox = hb,
                                ExplodesByFire = true,
                                MaxForcePerStudSquared = 450,
                                Model = m,
                                ImpactSpeed = 600,
                                ExplodesByPointy = false,
                                DestroysModel = true,
                                PositionPart = hb
                            },
                            tRoot.Position - Vector3.new(0, 2, 0)
                        }
                        bombExplode:FireServer(unpack(explosionArgs))
                    end
                end
            end
        end)
    end
end

-- 미사일 개수 표시
local missileCountLabel = MainTab:AddLabel("현재 미사일: 0/20")

-- [ 대기 회전 로직 ]
RunService.Heartbeat:Connect(function()
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not root or #missiles == 0 then return end
    
    local currentTime = tick() * 4
    local count = #missiles
    for i = count, 1, -1 do
        local m = missiles[i]
        local hb = m and m:FindFirstChild("HitboxBodyTop")
        if m and m.Parent and hb then
            local angle = (i / count) * (math.pi * 2) + currentTime
            local targetPos = root.Position + Vector3.new(math.cos(angle) * 12, 15, math.sin(angle) * 12)
            hb.CFrame = CFrame.new(targetPos, root.Position + Vector3.new(0, 15, 0))
            hb.AssemblyLinearVelocity = Vector3.zero
        else 
            table.remove(missiles, i) 
        end
    end
    
    missileCountLabel:Set("현재 미사일: " .. #missiles .. "/20")
end)

-- [ 키바인드 (F: 소환, G: 발사) ]
UIS.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.F then 
        spawnMissile()
        OrionLib:MakeNotification({
            Name = "🔫 미사일 소환",
            Content = "미사일이 생성되었습니다",
            Image = "rbxassetid://4483345998",
            Time = 1
        })
    elseif input.KeyCode == Enum.KeyCode.G then 
        fireAll()
    end
end)

-- UI 초기화 (필수)
OrionLib:Init()
